# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/zapcode
DATABASE_SSL=true

# ── Privy ──────────────────────────────────────────────────────────────────
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret
PRIVY_AUTHORIZATION_KEY=wallet-auth:YOUR_KEY

# ── Starknet ───────────────────────────────────────────────────────────────
STARKNET_RPC_URL=https://starknet-mainnet.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_ALCHEMY_KEY
STARKNET_NETWORK=mainnet

# ── Treasury wallet ────────────────────────────────────────────────────────
TREASURY_ADDRESS=0x...your_treasury_address
TREASURY_PRIVATE_KEY=0x...your_treasury_private_key

# ── AVNU Paymaster ─────────────────────────────────────────────────────────
AVNU_API_KEY=your_avnu_api_key

# ── Email ──────────────────────────────────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Image uploads ──────────────────────────────────────────────────────────
IMGBB_API_KEY=your_imgbb_api_key

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173